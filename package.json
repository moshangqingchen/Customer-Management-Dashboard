{
  "name": "startup-customer-workbench",
  "private": true,
  "version": "0.1.17",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:signed": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\build-tauri-signed.ps1",
    "update:manifest": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\create-update-manifest.ps1",
    "update:set-version": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\set-version.ps1",
    "update:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\verify-update-release.ps1",
    "update:publish:github": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\publish-github-update.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.8"
  }
}

{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "创业客户管理工作台",
    "version":  "0.1.16",
    "identifier":  "com.startup.customer-workbench",
    "build":  {
                  "beforeDevCommand":  "npm.cmd run dev",
                  "devUrl":  "http://localhost:1420",
                  "beforeBuildCommand":  "npm.cmd run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "创业客户管理工作台",
                                    "width":  1440,
                                    "height":  900,
                                    "minWidth":  1120,
                                    "minHeight":  720,
                                    "resizable":  true,
                                    "center":  true
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  [
                                   "nsis"
                               ],
                   "createUpdaterArtifacts":  true,
                   "windows":  {
                                   "nsis":  {
                                                "installMode":  "currentUser"
                                            }
                               }
               },
    "plugins":  {
                    "updater":  {
                                    "pubkey":  "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY4NjQ3NTdCQTlFMUQ2QUYKUldTdjF1R3BlM1ZrK0ZkMFN4OThaUVU5a1k3VEtkM2ZRL3VibzdHcXBvdnlEa2EzaWlPRnhjTU0K",
                                    "endpoints":  [
                                                      "https://github.com/moshangqingchen/Customer-Management-Dashboard/releases/latest/download/latest.json"
                                                  ]
                                }
                }
}